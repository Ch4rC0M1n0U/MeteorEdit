# ─── MeteorEdit Server Configuration ───
# Copy this file to .env and adjust values for your environment

# Server
PORT=3001
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb://localhost:27017/meteoredit

# JWT Secrets (CHANGE THESE — use: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_GENERATE_A_SECURE_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_A_SECURE_SECRET
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# File uploads
UPLOAD_DIR=./uploads

# Yjs real-time collaboration
YJS_PORT=3002

# Cookie encryption (for social integrations)
COOKIE_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_SECURE_SECRET

# LanguageTool (optional — spell checking)
LANGUAGETOOL_URL=http://localhost:8010

# Ollama AI (optional — local AI features)
OLLAMA_URL=http://localhost:11434
