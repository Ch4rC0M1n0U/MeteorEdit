{
  "name": "meteoredit-desktop",
  "version": "1.0.0",
  "description": "MeteorEdit Desktop Client for Windows",
  "main": "dist/main.js",
  "scripts": {
    "copy-static": "cp src/connect.html dist/connect.html",
    "dev": "tsc && npm run copy-static && electron .",
    "build": "tsc && npm run copy-static",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.6.0"
  }
}
