{
  "manifest_version": 3,
  "name": "MeteorEdit Cookie Bridge",
  "description": "Export social media cookies to MeteorEdit for OSINT investigations",
  "version": "1.0.0",
  "permissions": ["cookies", "storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.google.com/*",
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.snapchat.com/*",
    "*://*.facebook.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "*://*.threads.net/*",
    "*://*.linkedin.com/*",
    "*://*.strava.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
